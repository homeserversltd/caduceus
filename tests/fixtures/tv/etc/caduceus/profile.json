{
  "schema": "caduceus.profile.v1",
  "profile": "tv",
  "commands": ["identity show", "profile show", "health", "update status", "update now", "update service status", "update service toggle"],
  "services": {
    "update": {
      "timer": "harmonia-tv.timer",
      "latest_receipt": "/var/lib/harmonia/receipts/tv-latest/run.json"
    }
  },
  "harmonia_routes": {
    "update_now": {
      "bin": "/usr/local/bin/harmonia",
      "args": [
        "run-profile",
        "/etc/harmonia/profiles/tv/index.json",
        "--apply",
        "--receipt-dir",
        "/var/lib/harmonia/receipts/tv-latest"
      ]
    }
  }
}
